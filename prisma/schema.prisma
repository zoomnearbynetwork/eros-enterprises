generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  QUOTATION_SENT
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  REFERRAL
  CALL
  WALK_IN
  OTHER
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityEntityType {
  USER
  LEAD
  CUSTOMER
  SITE_VISIT
  SERVICE
  QUOTATION
  INVOICE
  PAYMENT
  PROJECT
  AMC_PLAN
  WHATSAPP_CONVERSATION
  WHATSAPP_MESSAGE
  AUTOMATION_RULE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ONBOARDING
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
  INSTITUTIONAL
}

enum SiteVisitStatus {
  SCHEDULED
  ASSIGNED
  COMPLETED
  RESCHEDULED
  CANCELLED
}

enum ActivityType {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_PRIORITY_CHANGED
  LEAD_ASSIGNED
  LEAD_CONVERTED_TO_CUSTOMER
  SITE_VISIT_SCHEDULED
  SITE_VISIT_UPDATED
  CUSTOMER_CREATED
  NOTE_ADDED
  QUOTATION_CREATED
  QUOTATION_UPDATED
  QUOTATION_STATUS_CHANGED
  QUOTATION_CONVERTED_TO_INVOICE
  INVOICE_CREATED
  INVOICE_UPDATED
  INVOICE_STATUS_CHANGED
  PAYMENT_RECORDED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_STAGE_CHANGED
  PROJECT_MANAGER_ASSIGNED
  PROJECT_ENGINEER_ASSIGNED
  PROJECT_PROGRESS_UPDATED
  AMC_PLAN_CREATED
  AMC_PLAN_UPDATED
  AMC_STATUS_CHANGED
  AMC_RENEWAL_RECORDED
  WHATSAPP_MESSAGE_RECEIVED
  WHATSAPP_MESSAGE_SENT
  AUTOMATION_RULE_CREATED
  AUTOMATION_RULE_UPDATED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  CARD
  OTHER
}

enum WhatsAppConversationStatus {
  OPEN
  ARCHIVED
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum WhatsAppProvider {
  MOCK
  META_CLOUD
  BAILEYS
}

enum AutomationTriggerType {
  LEAD_CREATED
  SITE_VISIT_SCHEDULED
  QUOTATION_SENT
  INVOICE_SENT
  PAYMENT_DUE
  AMC_RENEWAL_DUE
}

enum AutomationActionType {
  SEND_WHATSAPP_MESSAGE
  CREATE_TASK
  INTERNAL_NOTIFICATION
}

enum ProjectStage {
  PLANNED
  MATERIAL_ORDERED
  WORK_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CLOSED
}

enum AmcStatus {
  ACTIVE
  DUE_SOON
  EXPIRED
  RENEWED
  CANCELLED
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  passwordHash       String?
  firstName          String
  lastName           String?
  phone              String?
  status             UserStatus    @default(ACTIVE)
  roleId             String
  role               Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  assignedLeads      Lead[]        @relation("LeadAssignee")
  assignedSiteVisits SiteVisit[]   @relation("SiteVisitEngineer")
  managedProjects    Project[]     @relation("ProjectManager")
  assignedProjects   Project[]     @relation("ProjectEngineer")
  whatsappMessagesSent WhatsAppMessage[]
  activities         ActivityLog[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([roleId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id              String        @id @default(cuid())
  leadNumber      String        @unique
  name            String
  phone           String
  email           String?
  serviceInterest String
  source          LeadSource    @default(WEBSITE)
  sourcePage      String
  ctaLocation     String
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  message         String?
  location        String?
  budgetRange     String?
  status          LeadStatus    @default(NEW)
  priority        LeadPriority  @default(MEDIUM)
  assignedToId    String?
  assignedTo      User?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  customer        Customer?
  siteVisits      SiteVisit[]
  quotations      Quotation[]
  invoices        Invoice[]
  payments        Payment[]
  whatsappConversations WhatsAppConversation[]
  whatsappMessages WhatsAppMessage[]
  activities      ActivityLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([assignedToId])
  @@index([status, priority, source])
  @@index([sourcePage])
}

model Customer {
  id                 String         @id @default(cuid())
  customerNumber     String         @unique
  legalName          String
  primaryContactName String?
  email              String?        @unique
  phone              String?        @unique
  billingAddress     String?
  shippingAddress    String?
  gstin              String?        @unique
  notes              String?
  type               CustomerType   @default(INDIVIDUAL)
  status             CustomerStatus @default(ONBOARDING)
  leadId             String?        @unique
  lead               Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  siteVisits         SiteVisit[]
  quotations         Quotation[]
  invoices           Invoice[]
  payments           Payment[]
  projects           Project[]
  amcPlans           AmcPlan[]
  whatsappConversations WhatsAppConversation[]
  whatsappMessages   WhatsAppMessage[]
  activities         ActivityLog[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model SiteVisit {
  id                 String          @id @default(cuid())
  visitNumber        String          @unique
  leadId             String?
  lead               Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerId         String?
  customer           Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  serviceInterest    String
  scheduledAt        DateTime
  address            String
  notes              String?
  status             SiteVisitStatus @default(SCHEDULED)
  assignedEngineerId String?
  assignedEngineer   User?           @relation("SiteVisitEngineer", fields: [assignedEngineerId], references: [id], onDelete: SetNull)
  activities         ActivityLog[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([leadId])
  @@index([customerId])
  @@index([assignedEngineerId])
  @@index([status, scheduledAt])
}

model Service {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String        @unique
  description String?
  isActive    Boolean       @default(true)
  quotationItems QuotationItem[]
  invoiceItems InvoiceItem[]
  amcPlans      AmcPlan[]
  activities  ActivityLog[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Quotation {
  id             String          @id @default(cuid())
  quotationNumber String         @unique
  leadId         String?
  lead           Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerId     String?
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status         QuotationStatus @default(DRAFT)
  title          String?
  issueDate      DateTime        @default(now())
  validUntil     DateTime?
  notes          String?
  subtotalAmount Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal         @default(0) @db.Decimal(12, 2)
  discountAmount Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal         @default(0) @db.Decimal(12, 2)
  sentAt         DateTime?
  viewedAt       DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  expiredAt      DateTime?
  project        Project?
  invoice        Invoice?
  items          QuotationItem[]
  activities     ActivityLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([leadId])
  @@index([customerId])
  @@index([status, issueDate])
}

model QuotationItem {
  id             String    @id @default(cuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  serviceId      String?
  service        Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  name           String
  description    String?
  quantity       Decimal   @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal   @default(0) @db.Decimal(12, 2)
  taxRate        Decimal   @default(0) @db.Decimal(5, 2)
  lineSubtotal   Decimal   @default(0) @db.Decimal(12, 2)
  lineTaxAmount  Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal   @default(0) @db.Decimal(12, 2)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([quotationId, sortOrder])
  @@index([serviceId])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  quotationId    String?       @unique
  quotation      Quotation?    @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  leadId         String?
  lead           Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status         InvoiceStatus @default(DRAFT)
  title          String?
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  notes          String?
  subtotalAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  balanceAmount  Decimal       @default(0) @db.Decimal(12, 2)
  sentAt         DateTime?
  paidAt         DateTime?
  overdueAt      DateTime?
  cancelledAt    DateTime?
  items          InvoiceItem[]
  payments       Payment[]
  activities     ActivityLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([quotationId])
  @@index([leadId])
  @@index([customerId])
  @@index([status, dueDate])
}

model InvoiceItem {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId      String?
  service        Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  name           String
  description    String?
  quantity       Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice      Decimal  @default(0) @db.Decimal(12, 2)
  taxRate        Decimal  @default(0) @db.Decimal(5, 2)
  lineSubtotal   Decimal  @default(0) @db.Decimal(12, 2)
  lineTaxAmount  Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal      Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([invoiceId, sortOrder])
  @@index([serviceId])
}

model Payment {
  id            String        @id @default(cuid())
  paymentNumber String        @unique
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  amount        Decimal       @default(0) @db.Decimal(12, 2)
  method        PaymentMethod
  paidAt        DateTime      @default(now())
  reference     String?
  notes         String?
  activities    ActivityLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([invoiceId])
  @@index([leadId])
  @@index([customerId])
  @@index([paidAt])
}

model Project {
  id                 String        @id @default(cuid())
  projectNumber      String        @unique
  title              String
  description        String?
  stage              ProjectStage  @default(PLANNED)
  progressPercent    Int           @default(0)
  startDate          DateTime?
  targetCompletionDate DateTime?
  completedAt        DateTime?
  customerId         String
  customer           Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quotationId        String?       @unique
  quotation          Quotation?    @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  projectManagerId   String?
  projectManager     User?         @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  siteEngineerId     String?
  siteEngineer       User?         @relation("ProjectEngineer", fields: [siteEngineerId], references: [id], onDelete: SetNull)
  amcPlans           AmcPlan[]
  activities         ActivityLog[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([customerId])
  @@index([quotationId])
  @@index([projectManagerId])
  @@index([siteEngineerId])
  @@index([stage, targetCompletionDate])
}

model AmcPlan {
  id                 String      @id @default(cuid())
  amcNumber          String      @unique
  title              String
  description        String?
  status             AmcStatus   @default(ACTIVE)
  startDate          DateTime
  endDate            DateTime
  renewalDate        DateTime
  renewalReminderDays Int[]      @default([30, 15, 7])
  lastRenewedAt      DateTime?
  customerId         String
  customer           Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  projectId          String?
  project            Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  serviceId          String?
  service            Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  activities         ActivityLog[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([customerId])
  @@index([projectId])
  @@index([serviceId])
  @@index([status, renewalDate])
  @@index([endDate])
}

model WhatsAppConversation {
  id                 String                     @id @default(cuid())
  phone              String                     @unique
  displayName        String?
  status             WhatsAppConversationStatus @default(OPEN)
  provider           WhatsAppProvider           @default(MOCK)
  providerThreadKey  String?
  lastMessageAt      DateTime?
  lastDirection      WhatsAppMessageDirection?
  lastMessagePreview String?
  leadId             String?
  lead               Lead?                      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerId         String?
  customer           Customer?                  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages           WhatsAppMessage[]
  activities         ActivityLog[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([leadId])
  @@index([customerId])
  @@index([status, lastMessageAt])
}

model WhatsAppMessage {
  id                 String                   @id @default(cuid())
  conversationId     String
  conversation       WhatsAppConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction          WhatsAppMessageDirection
  status             WhatsAppMessageStatus    @default(QUEUED)
  provider           WhatsAppProvider         @default(MOCK)
  externalMessageId  String?
  body               String
  errorMessage       String?
  metadata           Json?
  leadId             String?
  lead               Lead?                    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerId         String?
  customer           Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sentByUserId       String?
  sentByUser         User?                    @relation(fields: [sentByUserId], references: [id], onDelete: SetNull)
  deliveredAt        DateTime?
  readAt             DateTime?
  failedAt           DateTime?
  activities         ActivityLog[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([conversationId, createdAt])
  @@index([leadId])
  @@index([customerId])
  @@index([sentByUserId])
  @@index([status, direction])
}

model AutomationRule {
  id                  String                @id @default(cuid())
  name                String
  description         String?
  triggerType         AutomationTriggerType
  actionType          AutomationActionType
  isActive            Boolean               @default(true)
  delayMinutes        Int                   @default(0)
  messageTemplate     String?
  taskTitle           String?
  taskDescription     String?
  notificationTitle   String?
  notificationMessage String?
  activities          ActivityLog[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([triggerType, isActive])
  @@index([actionType, isActive])
}

model ActivityLog {
  id             String             @id @default(cuid())
  type           ActivityType
  action         String
  description    String?
  metadata       Json?
  entityType     ActivityEntityType
  entityId       String
  userId         String?
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadId         String?
  lead           Lead?              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  siteVisitId    String?
  siteVisit      SiteVisit?         @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)
  serviceId      String?
  service        Service?           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  quotationId    String?
  quotation      Quotation?         @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  invoiceId      String?
  invoice        Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentId      String?
  payment        Payment?           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amcPlanId      String?
  amcPlan        AmcPlan?           @relation(fields: [amcPlanId], references: [id], onDelete: Cascade)
  whatsappConversationId String?
  whatsappConversation WhatsAppConversation? @relation(fields: [whatsappConversationId], references: [id], onDelete: Cascade)
  whatsappMessageId String?
  whatsappMessage WhatsAppMessage?  @relation(fields: [whatsappMessageId], references: [id], onDelete: Cascade)
  automationRuleId String?
  automationRule AutomationRule?    @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  occurredAt     DateTime           @default(now())
  createdAt      DateTime           @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([leadId])
  @@index([customerId])
  @@index([siteVisitId])
  @@index([serviceId])
  @@index([quotationId])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([projectId])
  @@index([amcPlanId])
  @@index([whatsappConversationId])
  @@index([whatsappMessageId])
  @@index([automationRuleId])
}
